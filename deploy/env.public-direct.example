# Public direct-binding profile only for intentionally exposed environments
# Prefer Nginx, Caddy, or Cloudflare Tunnel instead of this profile.
NODE_ENV=production
HOST=0.0.0.0
PORT=5000
STORAGE_BACKEND=file
DATA_FILE=.runtime/mavyclaw-data.json
AUTH_MODE=demo
SESSION_SECRET=replace-with-a-long-random-secret
TRUST_PROXY=
COOKIE_SECURE=false
DEMO_AUTH_USERNAME=demo-admin
DEMO_AUTH_PASSWORD=replace-with-a-strong-password
DEMO_AUTH_NAME=Demo Admin
DEMO_AUTH_ROLE=admin
AGENT_INGEST_TOKEN=replace-with-a-strong-agent-token
AGENT_INGEST_BASE_URL=http://your-server-ip:5000
