# VPS or VM profile with disk persistence behind a reverse proxy
NODE_ENV=production
HOST=127.0.0.1
PORT=5000
STORAGE_BACKEND=file
DATA_FILE=.runtime/mavyclaw-data.json
AUTH_MODE=demo
SESSION_SECRET=replace-with-a-long-random-secret
TRUST_PROXY=1
COOKIE_SECURE=auto
DEMO_AUTH_USERNAME=demo-admin
DEMO_AUTH_PASSWORD=replace-with-a-strong-password
DEMO_AUTH_NAME=Demo Admin
DEMO_AUTH_ROLE=admin
