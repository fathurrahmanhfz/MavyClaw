# Runtime
NODE_ENV=development
PORT=5000

# Database (optional for the current public snapshot)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Notes
# The current public snapshot can still run without DATABASE_URL
# because the default runtime still uses seeded in-memory storage.
# Fill in DATABASE_URL if you want to continue the Postgres/Drizzle integration path.
# Do not point it at production without explicit verification.
