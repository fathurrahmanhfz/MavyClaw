# Runtime
NODE_ENV=development
HOST=127.0.0.1
PORT=5000

# Runtime storage
# Development defaults to in-memory storage for fast local iteration.
# Production defaults to PostgreSQL automatically when DATABASE_URL is present.
# Otherwise production falls back to file-backed persistence at .runtime/mavyclaw-data.json.
# Accepted values: memory | file | postgres
STORAGE_BACKEND=memory
DATA_FILE=.runtime/mavyclaw-data.json

# Database
# When DATABASE_URL is set, runtime will use PostgreSQL unless STORAGE_BACKEND overrides it.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session access
# AUTH_MODE accepts open, demo, or configured.
# demo is useful for guarded single-operator environments and smoke testing.
AUTH_MODE=demo
SESSION_SECRET=change-this-session-secret
# Use TRUST_PROXY=1 when the app sits behind Nginx, Caddy, or another reverse proxy.
TRUST_PROXY=
# COOKIE_SECURE accepts false, true, or auto.
# auto is the safest default for HTTPS reverse-proxy deployments.
COOKIE_SECURE=auto
DEMO_AUTH_USERNAME=demo-admin
DEMO_AUTH_PASSWORD=demo-admin
DEMO_AUTH_NAME=Demo Admin
DEMO_AUTH_ROLE=admin
AUTH_USERNAME=operator
AUTH_PASSWORD=change-this-password
AUTH_NAME=Configured Operator
AUTH_ROLE=admin

# Notes
# The app can still run without DATABASE_URL.
# Use HOST=127.0.0.1 for reverse-proxy deployments on VPS or cloud servers.
# Set TRUST_PROXY=1 when the app is published through Nginx, Caddy, or a tunnel.
# Use STORAGE_BACKEND=file when you want disk persistence without PostgreSQL.
# Use STORAGE_BACKEND=postgres when you want to require PostgreSQL explicitly.
# Do not point experimental runtime changes at production without explicit verification.
