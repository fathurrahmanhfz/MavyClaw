# Runtime
NODE_ENV=development
PORT=5000

# Database (opsional untuk snapshot publik saat ini)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Catatan
# Snapshot publik saat ini tetap bisa dijalankan tanpa DATABASE_URL
# karena runtime default masih memakai seeded in-memory storage.
# Isi DATABASE_URL jika kamu ingin melanjutkan integrasi Postgres/Drizzle.
# Jangan arahkan ke production tanpa verifikasi.
