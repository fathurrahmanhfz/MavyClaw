# Runtime
NODE_ENV=development
PORT=5000

# Runtime storage
# Development defaults to in-memory storage for fast local iteration.
# Production defaults to file-backed persistence at .runtime/mavyclaw-data.json.
STORAGE_BACKEND=memory
DATA_FILE=.runtime/mavyclaw-data.json

# Database (optional for the current public snapshot)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Notes
# The current public snapshot can run without DATABASE_URL.
# Runtime persistence is now available through STORAGE_BACKEND=file.
# DATABASE_URL is still part of the future Postgres/Drizzle integration path.
# Do not point experimental runtime changes at production without explicit verification.
