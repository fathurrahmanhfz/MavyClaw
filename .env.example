# Runtime
NODE_ENV=development
PORT=5000

# Runtime storage
# Development defaults to in-memory storage for fast local iteration.
# Production defaults to PostgreSQL automatically when DATABASE_URL is present.
# Otherwise production falls back to file-backed persistence at .runtime/mavyclaw-data.json.
# Accepted values: memory | file | postgres
STORAGE_BACKEND=memory
DATA_FILE=.runtime/mavyclaw-data.json

# Database
# When DATABASE_URL is set, runtime will use PostgreSQL unless STORAGE_BACKEND overrides it.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Notes
# The app can still run without DATABASE_URL.
# Use STORAGE_BACKEND=file when you want disk persistence without PostgreSQL.
# Use STORAGE_BACKEND=postgres when you want to require PostgreSQL explicitly.
# Do not point experimental runtime changes at production without explicit verification.
